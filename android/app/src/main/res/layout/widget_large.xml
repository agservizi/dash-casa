<?xml version="1.0" encoding="utf-8"?>
<!-- Widget LARGE (4x4) — Dashboard completa -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:id="@+id/widget_root">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏠 Casa Nostra"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#F1F5F9" />

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#94A3B8" />
    </LinearLayout>

    <!-- Budget Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/widget_card_bg"
        android:padding="10dp"
        android:layout_marginBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💰 Budget mensile"
                android:textSize="11sp"
                android:textColor="#94A3B8" />

            <TextView
                android:id="@+id/widget_budget_daily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#38BDF8"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_budget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="€ 0 / € 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F1F5F9" />

        <ProgressBar
            android:id="@+id/widget_budget_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress" />
    </LinearLayout>

    <!-- Ultima spesa -->
    <LinearLayout
        android:id="@+id/widget_ultima_spesa_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/widget_card_bg"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧾 "
            android:textSize="13sp" />

        <TextView
            android:id="@+id/widget_ultima_spesa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#E2E8F0"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_ultima_spesa_importo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#F59E0B" />
    </LinearLayout>

    <!-- Riga con 2 colonne: Scadenze + Attività -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Scadenze (colonna sinistra) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_card_bg"
            android:padding="10dp"
            android:layout_marginEnd="3dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Scadenze"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/widget_scadenza1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E2E8F0"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_scadenza2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E2E8F0"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_scadenza3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E2E8F0"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_scadenza4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E2E8F0"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_scadenza5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E2E8F0"
                android:singleLine="true"
                android:ellipsize="end"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_no_scadenze"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ Nessuna"
                android:textSize="11sp"
                android:textColor="#10B981" />
        </LinearLayout>

        <!-- Attività (colonna destra) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_card_bg"
            android:padding="10dp"
            android:layout_marginStart="3dp">

            <TextView
                android:id="@+id/widget_attivita_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Attività"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/widget_attivita1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E2E8F0"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_attivita2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E2E8F0"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_attivita3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E2E8F0"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_attivita4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E2E8F0"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_attivita5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E2E8F0"
                android:singleLine="true"
                android:ellipsize="end"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_no_attivita"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎉 Tutto fatto!"
                android:textSize="11sp"
                android:textColor="#10B981" />
        </LinearLayout>
    </LinearLayout>

    <!-- Risparmio mensile (footer) -->
    <LinearLayout
        android:id="@+id/widget_risparmio_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/widget_card_bg"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐷 Risparmio: "
            android:textSize="11sp"
            android:textColor="#94A3B8" />

        <TextView
            android:id="@+id/widget_risparmio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#10B981" />

        <TextView
            android:id="@+id/widget_risparmio_goal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#94A3B8" />
    </LinearLayout>

</LinearLayout>
